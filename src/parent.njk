---
layout: layout.njk
title: Koko — Parents
extraCss: parent.css
extraJs:
  - timeUtils.js
  - storage.js
  - smiley.js
  - scheduleUtils.js
  - recurrence.js
  - calendar.js
  - parent.js
---

{% include "pin-gate.njk" %}

<div class="parent-content" id="parent-content" style="display:none">
  <header class="parent-header">
    <a class="btn-back-home" href="{{ '/' | url }}">← Retour</a>
    <span class="parent-title">Espace parent</span>
    <button class="btn-lock" id="btn-lock">🔒 Verrouiller</button>
  </header>

  <nav class="tab-bar">
    <button class="tab-btn tab-active" data-tab="tasks">📋 Tâches</button>
    <button class="tab-btn" data-tab="calendar">📅 Calendrier</button>
    <button class="tab-btn" data-tab="settings">⚙️ Réglages</button>
  </nav>

  <!-- Onglet Tâches -->
  <div class="tab-pane tab-pane-active" id="tab-tasks">
    <div class="pane-toolbar">
      <button class="btn-primary" id="btn-add-task">＋ Nouvelle tâche</button>
    </div>
    <ul class="task-list" id="task-list"></ul>

    <details class="archived-section">
      <summary class="archived-summary">Archivées</summary>
      <ul class="task-list" id="archived-list"></ul>
    </details>

    <details class="gallery-section">
      <summary class="archived-summary">Galerie d'images</summary>
      <div class="gallery-section-body">
        <div class="gallery-section-toolbar">
          <button type="button" class="btn-secondary" id="btn-gallery-import">📷 Importer une image</button>
          <input type="file" id="gallery-import-file" accept="image/*" style="display:none">
        </div>
        <div class="gallery-mgmt-grid" id="gallery-grid"></div>
        <p class="gallery-empty" id="gallery-empty-msg" style="display:none">Aucune image dans la galerie.</p>
      </div>
    </details>
  </div>

  <!-- Onglet Calendrier -->
  <div class="tab-pane" id="tab-calendar">
    <div id="parent-calendar"></div>
  </div>

  <!-- Onglet Paramètres -->
  <div class="tab-pane" id="tab-settings">
    <div class="settings-section">
      <h2 class="settings-title">Changer le code</h2>
      <div class="settings-form" id="settings-pin-form">
        <div class="form-group">
          <label class="form-label">Code actuel</label>
          <div class="pin-mini-dots" id="old-pin-dots">
            <span class="pin-dot"></span><span class="pin-dot"></span>
            <span class="pin-dot"></span><span class="pin-dot"></span>
          </div>
          <div class="pin-mini-keypad" id="old-pin-keypad" data-target="old"></div>
        </div>
        <div class="form-group" id="new-pin-group" style="display:none">
          <label class="form-label" id="new-pin-label">Nouveau code</label>
          <div class="pin-mini-dots" id="new-pin-dots">
            <span class="pin-dot"></span><span class="pin-dot"></span>
            <span class="pin-dot"></span><span class="pin-dot"></span>
          </div>
          <div class="pin-mini-keypad" id="new-pin-keypad" data-target="new"></div>
        </div>
        <p class="settings-error" id="settings-pin-error" aria-live="polite"></p>
        <p class="settings-success" id="settings-pin-success" aria-live="polite"></p>
      </div>
    </div>

    <div class="settings-section">
      <h2 class="settings-title">Prénom de l'enfant</h2>
      <div class="form-group">
        <label class="form-label" for="input-prenom">Prénom</label>
        <div class="prenom-row">
          <input class="form-input" type="text" id="input-prenom" placeholder="Koko" maxlength="30" autocomplete="off">
          <button class="btn-save" id="btn-save-prenom">OK</button>
        </div>
      </div>
      <p class="settings-success" id="prenom-success" aria-live="polite"></p>
    </div>

    <div class="settings-section">
      <h2 class="settings-title">Données</h2>
      <div class="data-actions">
        <button class="btn-data" id="btn-export">⬇️ Exporter les données</button>
        <button class="btn-data" id="btn-import">⬆️ Importer des données</button>
        <input type="file" id="import-file-input" accept="*/*" style="display:none">
      </div>
      <p class="settings-error" id="import-error" aria-live="polite"></p>
      <div class="form-group import-paste-group">
        <label class="form-label" for="import-paste-area">Ou coller le JSON ici</label>
        <textarea class="form-input import-paste-area" id="import-paste-area" rows="4" placeholder='{"koko:tasks": [...]}' spellcheck="false" autocorrect="off" autocapitalize="off"></textarea>
        <button class="btn-data" id="btn-import-paste">⬆️ Importer depuis le texte collé</button>
      </div>
    </div>
  </div>
</div>

<!-- Overlay : formulaire tâche -->
<div class="p-overlay" id="task-overlay" style="display:none">
  <div class="p-overlay-topbar">
    <button class="p-back-btn" id="task-overlay-back">← Retour</button>
    <span class="p-overlay-title" id="task-overlay-title">Nouvelle tâche</span>
    <button class="btn-save" id="task-save-btn">Enregistrer</button>
  </div>
  <div class="p-overlay-body">
    <input type="hidden" id="tf-id">

    <!-- Label -->
    <div class="form-group">
      <label class="form-label" for="tf-label">Nom de la tâche</label>
      <input class="form-input" type="text" id="tf-label" placeholder="Se brosser les dents" autocomplete="off">
    </div>

    <!-- Emoji / Image -->
    <div class="form-group">
      <label class="form-label">Emoji / Image</label>
      <div class="task-type-toggle">
        <button type="button" class="task-type-btn task-type-active" id="tf-type-emoji-btn">Emoji</button>
        <button type="button" class="task-type-btn" id="tf-type-image-btn">Image</button>
      </div>
      <div id="tf-emoji-group">
        <input class="form-input form-input-emoji" type="text" id="tf-emoji" maxlength="2" placeholder="🪥">
      </div>
      <div id="tf-image-group" style="display:none">
        <input type="file" id="tf-image-file" accept="image/*" style="display:none">
        <div class="image-btn-row">
          <button type="button" class="btn-secondary" id="tf-image-btn">📷 Importer</button>
          <button type="button" class="btn-secondary" id="tf-gallery-btn">🖼️ Galerie</button>
        </div>
        <div id="tf-image-preview" class="task-image-preview-wrap" style="display:none">
          <img id="tf-image-preview-img" class="task-image-preview" alt="Aperçu">
          <button type="button" class="btn-remove-image" id="tf-image-remove">✕ Retirer l'image</button>
        </div>
        <div id="tf-gallery-picker" style="display:none">
          <div class="gallery-picker-grid" id="tf-gallery-picker-grid"></div>
          <p class="gallery-empty" id="tf-gallery-picker-empty" style="display:none">Aucune image dans la galerie.</p>
        </div>
      </div>
    </div>

    <!-- Horaires -->
    <div class="form-group">
      <label class="form-label">Horaires</label>
      <ul class="schedules-list" id="schedules-list"></ul>
      <button type="button" class="btn-secondary" id="btn-add-schedule">＋ Ajouter un horaire</button>
    </div>

    <!-- Récurrence -->
    <div class="form-group">
      <label class="form-label">Récurrence</label>
      <div class="recurrence-row">
        <span class="recurrence-label">Répéter tous les</span>
        <input class="form-input form-input-sm" type="number" id="tf-every" min="1" value="1">
        <select class="form-select form-select-sm" id="tf-unit">
          <option value="days">jours</option>
          <option value="weeks">semaines</option>
          <option value="months">mois</option>
          <option value="years">années</option>
        </select>
      </div>

      <div id="tf-days-group" style="display:none">
        <div class="days-row">
          <label class="day-label"><input type="checkbox" name="tf-day" value="lundi">L</label>
          <label class="day-label"><input type="checkbox" name="tf-day" value="mardi">M</label>
          <label class="day-label"><input type="checkbox" name="tf-day" value="mercredi">M</label>
          <label class="day-label"><input type="checkbox" name="tf-day" value="jeudi">J</label>
          <label class="day-label"><input type="checkbox" name="tf-day" value="vendredi">V</label>
          <label class="day-label"><input type="checkbox" name="tf-day" value="samedi">S</label>
          <label class="day-label"><input type="checkbox" name="tf-day" value="dimanche">D</label>
        </div>
      </div>

      <div id="tf-month-day-group" style="display:none">
        <div class="recurrence-row">
          <span class="recurrence-label">Le</span>
          <input class="form-input form-input-sm" type="number" id="tf-day-of-month" min="1" max="31" placeholder="1">
          <span class="recurrence-label">du mois</span>
        </div>
      </div>

      <label class="form-checkbox">
        <input type="checkbox" id="tf-until-completion">
        Jusqu'à complétion
      </label>
    </div>

    <!-- Fin de récurrence -->
    <div class="form-group" id="tf-end-group">
      <label class="form-label">Fin de récurrence</label>
      <div class="radio-group">
        <label class="form-radio">
          <input type="radio" name="tf-end" value="never" checked>
          Jamais
        </label>
        <label class="form-radio">
          <input type="radio" name="tf-end" value="date">
          Le
          <input class="form-input form-input-inline" type="date" id="tf-end-date">
        </label>
        <label class="form-radio">
          <input type="radio" name="tf-end" value="occurrences">
          Après
          <input class="form-input form-input-sm" type="number" id="tf-end-occurrences" min="1" placeholder="10">
          occurrences
        </label>
      </div>
    </div>

    <!-- Exceptions -->
    <div class="form-group">
      <label class="form-label">Exceptions</label>
      <ul class="exceptions-list" id="exceptions-list"></ul>
      <div class="date-add-row">
        <input class="form-input" type="date" id="tf-exception-date">
        <button type="button" class="btn-secondary" id="btn-add-exception">Ajouter</button>
      </div>
    </div>

    <!-- Actions -->
    <div class="form-actions">
      <button type="button" class="btn-secondary" id="task-cancel-btn">Annuler</button>
      <button type="button" class="btn-primary" id="task-save-btn-bottom">Enregistrer</button>
    </div>

    <div id="tf-delete-group" style="display:none">
      <button type="button" class="btn-danger" id="task-delete-btn">Supprimer la tâche</button>
    </div>
  </div>
</div>

<!-- Overlay : validation rétroactive d'un jour -->
<div class="p-overlay" id="day-overlay" style="display:none">
  <div class="p-overlay-topbar">
    <button class="p-back-btn" id="day-overlay-back">← Retour</button>
    <span class="p-overlay-title" id="day-overlay-title"></span>
  </div>
  <div class="p-overlay-body">
    <div class="day-tasks-list" id="day-tasks-list"></div>
    <p class="day-empty" id="day-empty" style="display:none">Aucune tâche ce jour.</p>
  </div>
</div>
