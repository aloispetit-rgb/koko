<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#1A1A54">
  <title>{{ title or "Koko" }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@700;800&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/assets/icons/icon-192.png">
  <link rel="stylesheet" href="/assets/css/style.css">
  {% if extraCss %}<link rel="stylesheet" href="/assets/css/{{ extraCss }}">{% endif %}
</head>
<body>
  {{ content | safe }}
  {% if extraJs %}
  {% for js in extraJs %}
  <script src="/assets/js/{{ js }}"></script>
  {% endfor %}
  {% endif %}
</body>
</html>
